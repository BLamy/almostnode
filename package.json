{
  "name": "almostnode-workspace",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm nx serve-examples almostnode",
    "dev:web-ide": "pnpm nx dev web-ide",
    "dev:sdk-showcase": "pnpm vendor:install:opencode && pnpm nx dev sdk-showcase",
    "dev:mobile-ide": "pnpm nx dev mobile-ide",
    "vendor:install:opencode": "node scripts/vendor-install-opencode.js",
    "build": "pnpm nx run-many -t build",
    "build:lib": "pnpm nx build almostnode",
    "build:mobile-ide": "pnpm nx build mobile-ide",
    "build:types": "pnpm nx build-types almostnode",
    "test": "pnpm nx run-many -t test",
    "test:run": "pnpm nx run-many -t test",
    "test:e2e": "pnpm nx run-many -t e2e",
    "type-check": "pnpm nx run-many -t type-check"
  },
  "devDependencies": {
    "@nx/js": "^21.3.2",
    "@nx/vite": "^21.3.2",
    "@nx/playwright": "^21.3.2",
    "@playwright/test": "^1.58.0",
    "nx": "^21.3.2",
    "typescript": "^5.9.3"
  }
}
