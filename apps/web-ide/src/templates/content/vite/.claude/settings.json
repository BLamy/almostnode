{
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/task-git.sh",
            "timeout": 120,
            "statusMessage": "Committing task changes"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(npm *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(opencode)",
      "Bash(opencode *)",
      "Bash(npx shadcn *)",
